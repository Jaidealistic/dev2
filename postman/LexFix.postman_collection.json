                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', function () { pm.expect(pm.response.code).to.equal(200); });",
                                    "try {",
                                    "  var data = pm.response.json();",
                                    "  if(data.csrfToken) {",
                                    "    pm.environment.set('csrfToken', data.csrfToken);",
                                    "    console.log('✓ CSRF Token: ' + data.csrfToken.substring(0, 20));",
                                    "  }",
                                    "} catch(e) { console.log('Error parsing: ' + e); }"
                                ]
                            }
                        }
                    ],
